# Backtesting Engine environment reference.
# This repository does not load .env files automatically; export the variables
# you need in your shell or process manager.

# Runtime artifact locations.
BTE_RUNTIME__RUNTIME_ROOT=var/runtime
BTE_RUNTIME__NAUTILUS_ROOT=var/runtime/nautilus
BTE_RUNTIME__RESULTS_ROOT=results

# Market-data and normalized dataset locations.
BTE_DATA__SOURCE_CACHE_ROOT=data/cache
BTE_DATA__DATA_ROOT=var/data
BTE_DATA__CACHE_ROOT=var/cache
BTE_DATA__NORMALIZATION_POLICY=nautilus_v1

# Interactive Brokers / TWS defaults.
BTE_DATA__IB__HOST=127.0.0.1
BTE_DATA__IB__PORT=7497
BTE_DATA__IB__CLIENT_ID=1

# MetaTrader 5 defaults.
BTE_DATA__MT5__BROKER_TIMEZONE_NAME=Europe/Riga
# BTE_DATA__MT5__TERMINAL_PATH=C:/Program Files/MetaTrader 5/terminal64.exe
